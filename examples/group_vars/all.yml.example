---
# Example group_vars/all.yml for LinuxVitals.
#
# Copy this file to group_vars/all.yml next to your inventory and uncomment
# the values you want to override. Inventory / group_vars / extra-vars values
# override role defaults; role defaults live in:
#   roles/vitals_scan/defaults/main.yml   (thresholds, log windows)
#   roles/vitals_heal/defaults/main.yml   (self-healing opt-in)
#   roles/vitals_report/defaults/main.yml (output, archiving, notifications)

# linux_vitals_output_path: "{{ playbook_dir }}/reports/linux_vitals_report.html"
# linux_vitals_log_window: "30 minutes ago"
# linux_vitals_audit_log_window: "7 days ago"
# linux_vitals_ram_warning_threshold: 80
# linux_vitals_ram_critical_threshold: 95
# linux_vitals_boot_warning_threshold: 20

# Self-healing is disabled by default; opt in explicitly.
# linux_vitals_heal_enabled: true

# linux_vitals_slack_message_header: "Standard Maintenance Summary"
# linux_vitals_slack_message_footer: "Generated by LinuxVitals"
# linux_vitals_slack_include_host_breakdown: true
# linux_vitals_email_enabled: false
# linux_vitals_email_to:
#   - "ops@example.com"
# linux_vitals_email_from: "linux-vitals@example.com"
# linux_vitals_email_host: "smtp.example.com"
# linux_vitals_email_port: 587
# linux_vitals_email_secure: "starttls"
# linux_vitals_email_username: "smtp-user"
# linux_vitals_email_password: "smtp-password"
# linux_vitals_generic_webhook_enabled: true
# linux_vitals_generic_webhook_url: "https://example.com/health-events"
# linux_vitals_generic_webhook_headers:
#   Authorization: "Bearer example-token"
#
# Option 1: Set webhook/SMTP secrets directly here (not recommended for
# version-controlled inventories).
# linux_vitals_slack_webhook_url: "https://hooks.slack.com/services/your/team/webhook"
#
# Option 2 (recommended): store secrets in a local .env file as
# SLACK_WEBHOOK_URL=..., GENERIC_WEBHOOK_URL=..., EMAIL_SMTP_HOST=...,
# EMAIL_SMTP_USERNAME=..., EMAIL_SMTP_PASSWORD=... and vitals_report will
# auto-load them from {{ playbook_dir }}/.env. See .env.example.
