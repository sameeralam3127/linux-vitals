{
  "summary": {
    "header": {{ linux_vitals_slack_message_header | to_json }},
    "overall_status": {{ ('PASS' if linux_vitals_summary.critical_error_count | int == 0 else 'FAIL') | to_json }},
    "servers_checked": {{ linux_vitals_summary.servers_checked | int }},
    "auto_fixed_count": {{ linux_vitals_summary.auto_fixed_count | int }},
    "critical_error_count": {{ linux_vitals_summary.critical_error_count | int }},
    "snippet": {{ linux_vitals_summary.snippet | to_json }}
  },
  "message": {{ linux_vitals_notification_message | to_json }},
  "hosts": [
    {% for host in linux_vitals_reporting_hosts | default(ansible_play_hosts_all) %}
    {% set result = hostvars[host]['linux_vitals_result'] %}
    {
      "hostname": {{ result.hostname | to_json }},
      "ip_address": {{ result.ip_address | to_json }},
      "status": {{ result.final_status | to_json }},
      "platform_type": {{ result.platform_type | to_json }},
      "uptime": {{ result.uptime | to_json }},
      "running_kernel": {{ result.running_kernel | to_json }},
      "latest_kernel_selected": {{ result.latest_kernel_selected | to_json }},
      "reboot_required": {{ result.reboot_required | to_json }},
      "boot_space_status": {{ result.boot_space_status | to_json }},
      "failed_login_count": {{ result.failed_login_count | int }},
      "findings": {{ result.findings | to_json }}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
